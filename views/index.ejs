<%- include('partials/authHeader') %>

    <body>
        <%- include('partials/aside') %>

            <!-- <a href="/auth/logOut">logOut</a> -->
            <main class="main-wrapper">
                <!-- ========== header start ========== -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">
                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>
                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search..." />
                                            <button><i class="lni lni-search-alt"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <div class="dropdown">

                                        <a href="" class="text-decoration-none text-dark" id="profileDropdown"
                                            role="button" data-bs-toggle="dropdown" aria-expanded="false">

                                            <div class="profile-box">
                                                <div class="profile-info">
                                                    <div class="info d-flex align-items-center">

                                                        <div class="image me-2">
                                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                                alt="profile">
                                                        </div>

                                                        <div class="d-none d-sm-block">
                                                            <h6 class="fw-600 mb-0 text-capitalize">
                                                                <%= user.name %>
                                                            </h6>
                                                            <small class="text-muted">
                                                                <%= user.email %>
                                                            </small>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </a>

                                        <!-- Dropdown -->
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2"
                                            aria-labelledby="profileDropdown">

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                    <i class="lni lni-user me-2"></i>
                                                    My Profile
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                    <i class="lni lni-lock-alt me-2"></i>
                                                    Change Password
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <a class="dropdown-item logout-item" href="/auth/logout">
                                                    <i class="lni lni-exit"></i>
                                                    <span>Logout</span>
                                                </a>
                                            </li>

                                        </ul>

                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </header>
                <!-- ========== header end ========== -->

                <!-- Dashboard Section -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <!-- Welcome Card -->
                        <div class="card border-0 shadow-lg mb-4 overflow-hidden"
                            style="background:linear-gradient(135deg,#365cf5,#6c8dff);">

                            <div class="card-body p-5 text-white">

                                <div class="row align-items-center">

                                    <div class="col-lg-8">

                                        <h2 class="fw-bold mb-2">
                                            Welcome Back,
                                            <span class="text-capitalize">
                                                <%= user.name %>
                                            </span>
                                            👋
                                        </h2>

                                        <p class="mb-4 text-white-50">
                                            Manage products, profile information and website content
                                            from your dashboard.
                                        </p>

                                        <a href="/category/add" class="btn btn-light me-2">
                                            <i class="lni lni-plus me-2"></i>
                                            Create Category
                                        </a>

                                        <a href="/category/view-Category" class="btn btn-outline-light">
                                            View Categories
                                        </a>

                                    </div>

                                    <div class="col-lg-4 text-center mt-4 mt-lg-0">

                                        <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                            class="rounded-circle shadow" width="130" height="130"
                                            style="object-fit:cover; border:5px solid rgba(255,255,255,.3);">

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- Statistics -->
                        <div class="row">

                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-4">

                                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                            style="width:70px;height:70px;">
                                            <i class="lni lni-pencil fs-3"></i>
                                        </div>

                                        <h3 class="fw-bold mb-1">
                                            <%= totalCategories %>
                                        </h3>
                                        <p class="text-muted mb-0">
                                            Total Categories
                                        </p>

                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-4">

                                        <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                            style="width:70px;height:70px;">
                                            <i class="lni lni-eye fs-3"></i>
                                        </div>

                                        <h3 class="fw-bold mb-1">1.2K</h3>
                                        <p class="text-muted mb-0">
                                            Total Views
                                        </p>

                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-4">

                                        <div class="bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                            style="width:70px;height:70px;">
                                            <i class="lni lni-user fs-3"></i>
                                        </div>

                                        <h3 class="fw-bold mb-1">
                                            Active
                                        </h3>

                                        <p class="text-muted mb-0">
                                            Account Status
                                        </p>

                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-4">

                                        <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                            style="width:70px;height:70px;">
                                            <i class="lni lni-calendar fs-3"></i>
                                        </div>

                                        <h5 class="fw-bold mb-1">
                                            2026
                                        </h5>

                                        <p class="text-muted mb-0">
                                            Member Since
                                        </p>

                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- Bottom Section -->
                        <div class="row">

                            <!-- Quick Actions -->
                            <div class="col-lg-4 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-4">
                                            Quick Actions
                                        </h5>

                                        <div class="d-grid gap-3">

                                            <a href="/category/add" class="btn btn-primary">
                                                <i class="lni lni-plus me-2"></i>
                                                Create Category
                                            </a>

                                            <a href="/category/view-Category" class="btn btn-outline-primary">
                                                <i class="lni lni-list me-2"></i>
                                                View Categories
                                            </a>

                                            <a href="/dashboard/profile/edit" class="btn btn-outline-success">
                                                <i class="lni lni-pencil me-2"></i>
                                                Edit Profile
                                            </a>

                                            <a href="/auth/change-password" class="btn btn-outline-warning">
                                                <i class="lni lni-lock-alt me-2"></i>
                                                Change Password
                                            </a>

                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- User Information -->
                            <div class="col-lg-4 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-4">

                                        <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                            class="rounded-circle shadow mb-3" width="120" height="120"
                                            style="object-fit:cover;">

                                        <h4 class="fw-bold text-capitalize">
                                            <%= user.name %>
                                        </h4>

                                        <p class="text-muted mb-3">
                                            <%= user.email %>
                                        </p>

                                        <span class="badge bg-success px-3 py-2">
                                            Active Account
                                        </span>

                                        <hr>

                                        <p class="mb-1">
                                            <strong>Phone:</strong>
                                            <%= user.phone || 'Not Added Yet' %>
                                        </p>

                                        <p class="mb-0">
                                            <strong>Location:</strong>
                                            <%= user.location || 'Not Added Yet' %>
                                        </p>

                                    </div>
                                </div>
                            </div>

                            <!-- System Information -->
                            <div class="col-lg-4 mb-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-4">
                                            System Information
                                        </h5>

                                        <div class="d-flex justify-content-between mb-3">
                                            <span>Database</span>
                                            <span class="badge bg-success">
                                                Online
                                            </span>
                                        </div>

                                        <div class="d-flex justify-content-between mb-3">
                                            <span>Authentication</span>
                                            <span class="badge bg-success">
                                                Secure
                                            </span>
                                        </div>

                                        <div class="d-flex justify-content-between mb-3">
                                            <span>Profile Status</span>
                                            <span class="badge bg-primary">
                                                Completed
                                            </span>
                                        </div>

                                        <hr>

                                        <h6 class="fw-bold">
                                            About Me
                                        </h6>

                                        <p class="text-muted mb-0">
                                            <%= user.about || 'Tell us something about yourself...' %>
                                        </p>

                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                </section>
            </main>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>


    </html>