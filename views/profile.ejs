<%- include('partials/authHeader') %>

    <body>
        <%- include('partials/aside') %>

            <!-- <a href="/auth/logOut">logOut</a> -->
            <main class="main-wrapper">
                <!-- ========== header start ========== -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">
                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>
                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search..." />
                                            <button><i class="lni lni-search-alt"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <div class="dropdown">

                                        <a href="" class="text-decoration-none text-dark" id="profileDropdown"
                                            role="button" data-bs-toggle="dropdown" aria-expanded="false">

                                            <div class="profile-box">
                                                <div class="profile-info">
                                                    <div class="info d-flex align-items-center">

                                                        <div class="image me-2">
                                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                                alt="profile">
                                                        </div>

                                                        <div class="d-none d-sm-block">
                                                            <h6 class="fw-600 mb-0 text-capitalize">
                                                                <%= user.name %>
                                                            </h6>
                                                            <small class="text-muted">
                                                                <%= user.email %>
                                                            </small>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </a>

                                        <!-- Dropdown -->
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2"
                                            aria-labelledby="profileDropdown">

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                    <i class="lni lni-user me-2"></i>
                                                    My Profile
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                    <i class="lni lni-lock-alt me-2"></i>
                                                    Change Password
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <a class="dropdown-item logout-item" href="/auth/logout">
                                                    <i class="lni lni-exit"></i>
                                                    <span>Logout</span>
                                                </a>
                                            </li>

                                        </ul>

                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </header>
                <!-- ========== header end ========== -->

                <!-- ========== Profile Section Start ========== -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <!-- Page Heading -->
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
                                <div>
                                    <h3 class="fw-bold mb-1">My Profile</h3>
                                    <p class="text-muted mb-0">
                                        Manage your personal information and account details.
                                    </p>
                                </div>

                                <a href="/dashboard/profile/edit" class="btn btn-primary mt-3 mt-md-0">
                                    <i class="lni lni-pencil me-2"></i>
                                    Edit Profile
                                </a>
                            </div>
                        </div>

                        <div class="row">

                            <!-- Left Profile Card -->
                            <div class="col-lg-4 mb-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-body text-center p-5">

                                        <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                            class="rounded-circle shadow mb-4" width="130" height="130"
                                            style="object-fit:cover;" alt="profile">

                                        <h4 class="fw-bold mb-1 text-capitalize">
                                            <%= user.name %>
                                        </h4>

                                        <p class="text-muted mb-3">
                                            Blog Management Administrator
                                        </p>

                                        <span class="badge bg-success px-3 py-2">
                                            Active Account
                                        </span>

                                        <hr class="my-4">

                                        <div class="text-start">

                                            <div class="mb-3">
                                                <small class="text-muted d-block">
                                                    Email Address
                                                </small>
                                                <strong>
                                                    <%= user.email %>
                                                </strong>
                                            </div>

                                            <div class="mb-3">
                                                <small class="text-muted d-block">
                                                    Phone Number
                                                </small>

                                                <% if (user.phone) { %>
                                                    <strong>
                                                        <%= user.phone %>
                                                    </strong>
                                                    <% } else { %>
                                                        <span class="text-muted fst-italic">
                                                            Not Added Yet
                                                        </span>
                                                        <% } %>
                                            </div>

                                            <div>
                                                <small class="text-muted d-block">
                                                    Location
                                                </small>

                                                <% if (user.location) { %>
                                                    <strong>
                                                        <%= user.location %>
                                                    </strong>
                                                    <% } else { %>
                                                        <span class="text-muted fst-italic">
                                                            Not Added Yet
                                                        </span>
                                                        <% } %>
                                            </div>

                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- Right Details -->
                            <div class="col-lg-8">

                                <!-- Personal Information -->
                                <div class="card shadow-sm border-0 mb-4">
                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-4">
                                            Personal Information
                                        </h5>

                                        <div class="row">

                                            <div class="col-md-6 mb-4">
                                                <label class="form-label text-muted">
                                                    Full Name
                                                </label>
                                                <input type="text" class="form-control text-capitalize"
                                                    value="<%= user.name %>" readonly>
                                            </div>

                                            <div class="col-md-6 mb-4">
                                                <label class="form-label text-muted">
                                                    Email Address
                                                </label>
                                                <input type="text" class="form-control" value="<%= user.email %>"
                                                    readonly>
                                            </div>

                                            <div class="col-md-6 mb-4">
                                                <label class="form-label text-muted">
                                                    Date of Birth
                                                </label>
                                                <input type="text"
                                                    class="form-control <%= !user.dob ? 'text-muted fst-italic' : '' %>"
                                                    value="<%= user.dob ? new Date(user.dob).toLocaleDateString('en-GB') : 'Not Added Yet' %>"
                                                    readonly>
                                            </div>

                                            <div class="col-md-6 mb-4">
                                                <label class="form-label text-muted">
                                                    Phone Number
                                                </label>
                                                <input type="text"
                                                    class="form-control <%= !user.phone ? 'text-muted fst-italic' : '' %>"
                                                    value="<%= user.phone || 'Not Added Yet' %>" readonly>
                                            </div>

                                            <div class="col-md-12">
                                                <label class="form-label text-muted">
                                                    About Me
                                                </label>

                                                <textarea
                                                    class="form-control <%= !user.about ? 'text-muted fst-italic' : '' %>"
                                                    rows="4"
                                                    readonly><%= user.about || 'Tell us something about yourself...' %></textarea>
                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <!-- Account Statistics -->
                                <!-- Account Information Cards -->
                                <div class="row">

                                    <!-- Account Role -->
                                    <div class="col-md-4 mb-4">
                                        <div class="card shadow-sm border-0">
                                            <div class="card-body text-center">

                                                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                                    style="width:60px;height:60px;">
                                                    <i class="lni lni-user fs-4"></i>
                                                </div>

                                                <h5 class="fw-bold">Administrator</h5>
                                                <p class="text-muted mb-0">
                                                    Account Role
                                                </p>

                                            </div>
                                        </div>
                                    </div>

                                    <!-- Member Since -->
                                    <div class="col-md-4 mb-4">
                                        <div class="card shadow-sm border-0">
                                            <div class="card-body text-center">

                                                <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                                    style="width:60px;height:60px;">
                                                    <i class="lni lni-calendar fs-4"></i>
                                                </div>

                                                <h5 class="fw-bold">January 2026</h5>
                                                <p class="text-muted mb-0">
                                                    Member Since
                                                </p>

                                            </div>
                                        </div>
                                    </div>

                                    <!-- Account Status -->
                                    <div class="col-md-4 mb-4">
                                        <div class="card shadow-sm border-0">
                                            <div class="card-body text-center">

                                                <div class="bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                                    style="width:60px;height:60px;">
                                                    <i class="lni lni-shield fs-4"></i>
                                                </div>

                                                <h5 class="fw-bold">Verified</h5>
                                                <p class="text-muted mb-0">
                                                    Account Status
                                                </p>

                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                </section>
                <!-- ========== Profile Section End ========== -->

            </main>


            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>


    </html>