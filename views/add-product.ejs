<%- include('partials/authHeader') %>

    <body>

        <%- include('partials/aside') %>

            <main class="main-wrapper">

                <!-- Header -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">

                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">

                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>

                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search..." />
                                            <button>
                                                <i class="lni lni-search-alt"></i>
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>

                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <div class="dropdown">

                                        <a href="#" class="text-decoration-none text-dark" id="profileDropdown"
                                            role="button" data-bs-toggle="dropdown">

                                            <div class="profile-box">
                                                <div class="profile-info">
                                                    <div class="info d-flex align-items-center">

                                                        <div class="image me-2">
                                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                                alt="profile">
                                                        </div>

                                                        <div class="d-none d-sm-block">
                                                            <h6 class="fw-600 mb-0 text-capitalize">
                                                                <%= user.name %>
                                                            </h6>

                                                            <small class="text-muted">
                                                                <%= user.email %>
                                                            </small>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </a>

                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2">

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                    <i class="lni lni-user me-2"></i>
                                                    My Profile
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                    <i class="lni lni-lock-alt me-2"></i>
                                                    Change Password
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <a class="dropdown-item logout-item" href="/auth/logout">
                                                    <i class="lni lni-exit"></i>
                                                    <span>Logout</span>
                                                </a>
                                            </li>

                                        </ul>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </header>

                <!-- Add Product Section -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <div class="row">
                            <div class="col-12">

                                <div class="card-style">

                                    <div class="title mb-4">
                                        <h4>Add New Product</h4>
                                        <p class="text-sm text-medium">
                                            Create a new product for your store.
                                        </p>
                                    </div>

                                    <% if(errorMsg){ %>
                                        <div class="alert alert-danger">
                                            <%= errorMsg %>
                                        </div>
                                        <% } %>

                                            <% if(categories.length===0){ %>

                                                <div
                                                    class="alert alert-warning d-flex justify-content-between align-items-center mb-4">

                                                    <div>
                                                        <i class="lni lni-warning me-2"></i>
                                                        <strong>No categories found.</strong> Please add a category
                                                        before creating a product.
                                                    </div>

                                                    <a href="/category/add" class="btn btn-warning btn-sm">
                                                        <i class="lni lni-plus me-1"></i>
                                                        Add Category
                                                    </a>

                                                </div>

                                                <% } %>

                                                    <form action="/product/addProduct" method="POST"
                                                        enctype="multipart/form-data">

                                                        <div class="row">

                                                            <!-- Category -->
                                                            <div class="col-md-6">
                                                                <div class="select-style-1">

                                                                    <label>Category</label>

                                                                    <div class="select-position">

                                                                        <% if(categories.length> 0){ %>

                                                                            <select name="category" required>

                                                                                <option value="">
                                                                                    Select Category
                                                                                </option>

                                                                                <% categories.forEach(category=>{ %>

                                                                                    <option value="<%= category._id %>">
                                                                                        <%= category.categoryName %>
                                                                                    </option>

                                                                                    <% }) %>

                                                                            </select>

                                                                            <% } else { %>

                                                                                <select disabled>
                                                                                    <option>
                                                                                        No Categories Available
                                                                                    </option>
                                                                                </select>

                                                                                <% } %>

                                                                    </div>

                                                                </div>
                                                            </div>

                                                            <!-- Product Name -->
                                                            <div class="col-md-6">
                                                                <div class="input-style-1">

                                                                    <label>Product Name</label>

                                                                    <input type="text" name="productName"
                                                                        placeholder="Enter product name" required
                                                                        <%=categories.length===0 ? 'disabled' : '' %>>

                                                                </div>
                                                            </div>

                                                            <!-- Product Price -->
                                                            <div class="col-md-6">
                                                                <div class="input-style-1">

                                                                    <label>Product Price</label>

                                                                    <input type="number" name="productPrice"
                                                                        placeholder="Enter product price" min="1"
                                                                        required <%=categories.length===0 ? 'disabled'
                                                                        : '' %>>

                                                                </div>
                                                            </div>

                                                            <!-- Product Image -->
                                                            <div class="col-md-6">
                                                                <div class="input-style-1">

                                                                    <label>Product Image</label>

                                                                    <input type="file" 
                                                                    required name="productImage"
                                                                        <%=categories.length===0
                                                                        ? 'disabled' : '' %>>


                                                                </div>
                                                            </div>

                                                            <!-- Description -->
                                                            <div class="col-md-12">
                                                                <div class="input-style-1">

                                                                    <label>Description</label>

                                                                    <textarea name="productDescription" rows="5"
                                                                        placeholder="Enter product description" required
                                                                        <%=categories.length===0 ? 'disabled' : ''
                                                                        %>></textarea>

                                                                </div>
                                                            </div>

                                                            <!-- Submit -->
                                                            <div class="col-md-12">

                                                                <button type="submit"
                                                                    class="main-btn primary-btn btn-hover w-100"
                                                                    <%=categories.length===0 ? 'disabled' : '' %>>

                                                                    Add Product

                                                                </button>

                                                            </div>

                                                        </div>

                                                    </form>

                                </div>

                            </div>
                        </div>

                    </div>
                </section>

            </main>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    </body>

    </html>