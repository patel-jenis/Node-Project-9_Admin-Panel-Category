<%- include('partials/authHeader') %>

    <body>
        <%- include('partials/aside') %>

            <main class="main-wrapper">

                <!-- Header -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">
                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>
                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search..." />
                                            <button><i class="lni lni-search-alt"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <div class="dropdown">

                                        <a href="" class="text-decoration-none text-dark" id="profileDropdown"
                                            role="button" data-bs-toggle="dropdown" aria-expanded="false">

                                            <div class="profile-box">
                                                <div class="profile-info">
                                                    <div class="info d-flex align-items-center">

                                                        <div class="image me-2">
                                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                                alt="profile">
                                                        </div>

                                                        <div class="d-none d-sm-block">
                                                            <h6 class="fw-600 mb-0 text-capitalize">
                                                                <%= user.name %>
                                                            </h6>
                                                            <small class="text-muted">
                                                                <%= user.email %>
                                                            </small>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </a>

                                        <!-- Dropdown -->
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2"
                                            aria-labelledby="profileDropdown">

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                    <i class="lni lni-user me-2"></i>
                                                    My Profile
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                    <i class="lni lni-lock-alt me-2"></i>
                                                    Change Password
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <a class="dropdown-item logout-item" href="/auth/logout">
                                                    <i class="lni lni-exit"></i>
                                                    <span>Logout</span>
                                                </a>
                                            </li>

                                        </ul>

                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                <!-- Edit Profile Section -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">
                                <h3 class="fw-bold mb-1">
                                    Edit Profile
                                </h3>
                                <p class="text-muted mb-0">
                                    Update your personal information and account details.
                                </p>
                            </div>
                        </div>

                        <form action="/dashboard/profile/update" method="POST" enctype="multipart/form-data">

                            <div class="row">

                                <!-- Left Card -->
                                <div class="col-lg-4 mb-4">

                                    <div class="card shadow-sm border-0">
                                        <div class="card-body text-center p-5">

                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                class="rounded-circle shadow mb-4" width="140" height="140"
                                                style="object-fit: cover;" alt="profile">

                                            <h5 class="fw-bold text-capitalize mb-1">
                                                <%= user.name %>
                                            </h5>

                                            <p class="text-muted mb-4">
                                                Blog Management Administrator
                                            </p>

                                            <div class="text-start">
                                                <label class="form-label">
                                                    Profile Image
                                                </label>

                                                <input type="file" name="image" class="form-control">
                                            </div>

                                        </div>
                                    </div>

                                </div>

                                <!-- Right Card -->
                                <div class="col-lg-8">

                                    <div class="card shadow-sm border-0">
                                        <div class="card-body p-4">

                                            <h5 class="fw-bold mb-4">
                                                Personal Information
                                            </h5>

                                            <div class="row">

                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label">
                                                        Full Name
                                                    </label>

                                                    <input type="text" name="name" class="form-control text-capitalize"
                                                        value="<%= user.name %>">
                                                </div>

                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label">
                                                        Email Address
                                                    </label>

                                                    <input type="email" name="email" class="form-control"
                                                        value="<%= user.email %>" disabled>
                                                </div>

                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label">
                                                        Date of Birth
                                                    </label>

                                                    <input type="date" name="dob" class="form-control"
                                                        value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>">
                                                </div>

                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label">
                                                        Phone Number
                                                    </label>

                                                    <input type="text" name="phone" class="form-control"
                                                        placeholder="+91 9876543210" value="<%= user.phone || '' %>">
                                                </div>

                                                <div class="col-md-12 mb-4">
                                                    <label class="form-label">
                                                        Location
                                                    </label>

                                                    <input type="text" name="location" class="form-control"
                                                        placeholder="Surat, Gujarat, India"
                                                        value="<%= user.location || '' %>">
                                                </div>

                                                <div class="col-md-12 mb-4">
                                                    <label class="form-label">
                                                        About Me
                                                    </label>

                                                    <textarea name="about" rows="5" class="form-control"
                                                        placeholder="Tell us something about yourself..."><%= user.about || '' %></textarea>
                                                </div>

                                            </div>

                                            <div class="d-flex gap-3">

                                                <button type="submit" class="btn btn-primary px-4">
                                                    <i class="lni lni-save me-2"></i>
                                                    Save Changes
                                                </button>

                                                <a href="/dashboard/profile" class="btn btn-outline-secondary px-4">
                                                    Cancel
                                                </a>

                                            </div>

                                        </div>
                                    </div>

                                </div>

                            </div>

                        </form>

                    </div>
                </section>

            </main>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>