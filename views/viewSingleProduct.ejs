<%- include('partials/authHeader') %>

    <body>

        <%- include('partials/aside') %>

            <main class="main-wrapper">

                <!-- Header -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">

                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">

                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>

                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search...">
                                            <button>
                                                <i class="lni lni-search-alt"></i>
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>

                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <div class="dropdown">

                                        <a href="#" class="text-decoration-none text-dark" data-bs-toggle="dropdown">

                                            <div class="profile-box">
                                                <div class="profile-info">
                                                    <div class="info d-flex align-items-center">

                                                        <div class="image me-2">
                                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                                alt="profile">
                                                        </div>

                                                        <div class="d-none d-sm-block">
                                                            <h6 class="fw-600 mb-0 text-capitalize">
                                                                <%= user.name %>
                                                            </h6>

                                                            <small class="text-muted">
                                                                <%= user.email %>
                                                            </small>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </a>

                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2">

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                    <i class="lni lni-user me-2"></i>
                                                    My Profile
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                    <i class="lni lni-lock-alt me-2"></i>
                                                    Change Password
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <a class="dropdown-item logout-item" href="/auth/logout">
                                                    <i class="lni lni-exit"></i>
                                                    Logout
                                                </a>
                                            </li>

                                        </ul>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </header>

                <!-- Product Details -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <div class="card-style shadow-sm">

                            <!-- Title -->
                            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">

                                <div>
                                    <h3 class="fw-bold mb-1">Product Details</h3>
                                    <p class="text-muted mb-0">
                                        View complete product information.
                                    </p>
                                </div>

                                <div>

                                    <a href="/product/view-product" class="btn btn-secondary me-2">
                                        <i class="lni lni-arrow-left me-1"></i>
                                        Back
                                    </a>

                                    <a href="/product/edit/<%= product._id %>" class="btn btn-warning me-2">
                                        <i class="lni lni-pencil me-1"></i>
                                        Edit
                                    </a>

                                    <a href="/product/delete/<%= product._id %>"
                                        onclick="return confirm('Delete this product?')" class="btn btn-danger">
                                        <i class="lni lni-trash-can me-1"></i>
                                        Delete
                                    </a>

                                </div>

                            </div>

                            <div class="row">

                                <!-- Image -->
                                <div class="col-lg-5 mb-4">

                                    <div class="border rounded-4 p-3 bg-light text-center">
                                        <img src="/<%= product.productImage %>" class="img-fluid rounded-3"
                                            style="height:420px; width:100%; object-fit:contain;">

                                    </div>

                                </div>

                                <!-- Details -->
                                <div class="col-lg-7">

                                    <h2 class="fw-bold mb-2">
                                        <%= product.productName %>
                                    </h2>

                                    <span class="badge bg-primary fs-6 px-3 py-2 mb-3">
                                        <%= category.categoryName %>
                                    </span>

                                    <div class="card border-success mb-4">

                                        <div class="card-body">

                                            <h6 class="text-muted mb-1">
                                                Product Price
                                            </h6>

                                            <h2 class="text-success fw-bold mb-0">
                                                ₹ <%= product.productPrice %>
                                            </h2>

                                        </div>

                                    </div>

                                    <div class="mb-4">

                                        <h5 class="fw-bold">
                                            Description
                                        </h5>

                                        <p class="text-muted">
                                            <%= product.productDescription %>
                                        </p>

                                    </div>

                                    <div class="row">

                                        <div class="col-md-6 mb-3">

                                            <div class="border rounded-3 p-3">

                                                <small class="text-muted">
                                                    Created At
                                                </small>

                                                <h6 class="mt-2 mb-0">
                                                    <%= product.createdAt.toLocaleString() %>
                                                </h6>

                                            </div>

                                        </div>

                                        <div class="col-md-6 mb-3">

                                            <div class="border rounded-3 p-3">

                                                <small class="text-muted">
                                                    Updated At
                                                </small>

                                                <h6 class="mt-2 mb-0">
                                                    <%= product.updatedAt.toLocaleString() %>
                                                </h6>

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                </section>

            </main>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    </body>

    </html>