<%- include('partials/authHeader') %>

    <body>

        <main class="min-vh-100 d-flex align-items-center justify-content-center bg-light">

            <div class="container">
                <div class="row justify-content-center">

                    <div class="col-lg-11 col-xl-10">

                        <div class="card shadow-lg border-0 overflow-hidden">

                            <div class="row g-0">

                                <!-- Left Side -->
                                <div
                                    class="col-md-6 bg-primary-100 d-flex align-items-center justify-content-center p-5">

                                    <div class="text-center">

                                        <h1 class="text-primary mb-3">
                                            Forgot Password
                                        </h1>

                                        <p class="text-medium mb-4">
                                            Enter your registered email address to reset your password.
                                        </p>

                                        <img src="../assets/images/auth/signin-image.svg" alt="forgot-password-image"
                                            class="img-fluid w-75">

                                    </div>

                                </div>

                                <!-- Right Side -->
                                <div class="col-md-6 d-flex align-items-center">

                                    <div class="w-100 p-sm-5 p-4">

                                        <h3 class="mb-3">
                                            Forgot Password
                                        </h3>

                                        <p class="text-muted mb-4">
                                            Enter your registered email and we'll help you reset your password.
                                        </p>

                                        <% if(errorMsg) { %>
                                            <div class="alert alert-danger py-2 px-3 mb-3">
                                                <%= errorMsg %>
                                            </div>
                                            <% } %>

                                                <form action="/auth/forgot-password" method="POST">

                                                    <div class="mb-3">

                                                        <label class="form-label">
                                                            Email Address
                                                        </label>

                                                        <input type="email" name="email" class="form-control"
                                                            placeholder="Enter your registered email" required>

                                                    </div>

                                                    <button type="submit" class="btn btn-primary w-100 mt-3 py-2">

                                                        Continue

                                                    </button>

                                                    <div class="text-center mt-3">

                                                        <a href="/auth/signIn" class="text-decoration-none fw-semibold">

                                                            ← Back to Sign In

                                                        </a>

                                                    </div>

                                                </form>

                                    </div>

                                </div>
                                <!-- End Right Side -->

                            </div>

                        </div>

                    </div>

                </div>
            </div>

        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    </body>

    </html>