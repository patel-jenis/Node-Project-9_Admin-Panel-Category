<%- include('partials/authHeader') %>

    <body>

        <%- include('partials/aside') %>

            <main class="main-wrapper">

                <!-- Header -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">

                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">

                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>

                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search...">
                                            <button>
                                                <i class="lni lni-search-alt"></i>
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>

                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <div class="dropdown">

                                        <a href="#" class="text-decoration-none text-dark" id="profileDropdown"
                                            role="button" data-bs-toggle="dropdown">

                                            <div class="profile-box">
                                                <div class="profile-info">
                                                    <div class="info d-flex align-items-center">

                                                        <div class="image me-2">
                                                            <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                                alt="profile">
                                                        </div>

                                                        <div class="d-none d-sm-block">
                                                            <h6 class="fw-600 mb-0 text-capitalize">
                                                                <%= user.name %>
                                                            </h6>

                                                            <small class="text-muted">
                                                                <%= user.email %>
                                                            </small>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </a>

                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2">

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                    <i class="lni lni-user me-2"></i>
                                                    My Profile
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                    <i class="lni lni-lock-alt me-2"></i>
                                                    Change Password
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <a class="dropdown-item logout-item" href="/auth/logout">
                                                    <i class="lni lni-exit"></i>
                                                    Logout
                                                </a>
                                            </li>

                                        </ul>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </header>

                <% if(messages.success){ %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= messages.success %>

                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <% if(messages.error){ %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <%= messages.error %>

                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                            <% } %>

                                <!-- View Products Section -->
                                <section class="section mt-5">
                                    <div class="container-fluid">

                                        <div class="card-style shadow-sm">

                                            <!-- Header -->
                                            <div
                                                class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">

                                                <div>
                                                    <h4 class="mb-1 fw-bold">All Products</h4>
                                                    <p class="text-muted mb-0">
                                                        Manage and organize your products.
                                                    </p>
                                                </div>

                                                <a href="/product/add"
                                                    class="main-btn py-2 px-3 rounded-3 primary-btn btn-hover">
                                                    <i class="lni lni-plus me-2"></i>
                                                    Add Product
                                                </a>

                                            </div>

                                            <!-- Table -->
                                            <div class="table-responsive">

                                                <table class="table align-middle">

                                                    <thead class="table-light">
                                                        <tr>
                                                            <th width="60">#</th>
                                                            <th width="90">Image</th>
                                                            <th>Product Name</th>
                                                            <th>Category</th>
                                                            <th>Price</th>
                                                            <th width="180" class="text-center">
                                                                Actions
                                                            </th>
                                                        </tr>
                                                    </thead>

                                                    <tbody>

                                                        <% products.forEach((product, index)=> { %>

                                                            <tr>

                                                                <!-- Index -->
                                                                <td>
                                                                    <strong>
                                                                        <%= index + 1 %>
                                                                    </strong>
                                                                </td>

                                                                <!-- Image -->
                                                                <td>
                                                                    <img src="/<%= product.productImage %>"
                                                                        alt="Product" width="60" height="60"
                                                                        class="rounded border"
                                                                        style="object-fit: cover;">
                                                                </td>

                                                                <!-- Product Name -->
                                                                <td>
                                                                    <strong>
                                                                        <%= product.productName %>
                                                                    </strong>
                                                                </td>

                                                                <!-- Category -->
                                                                <td>
                                                                    <span
                                                                        class="badge bg-primary px-3 py-2 rounded-pill">
                                                                        <%= product.category %>
                                                                    </span>
                                                                </td>

                                                                <!-- Price -->
                                                                <td>
                                                                    ₹ <%= product.productPrice %>
                                                                </td>

                                                                <!-- Actions -->
                                                                <td>

                                                                    <div
                                                                        class="action-btns d-flex justify-content-center gap-2">

                                                                        <!-- View -->
                                                                        <a href="/product/view/<%= product._id %>"
                                                                            class="btn btn-info btn-sm text-white"
                                                                            title="View">
                                                                            <i class="lni lni-eye"></i>
                                                                        </a>

                                                                        <!-- Edit -->
                                                                        <a href="/product/edit/<%= product._id %>"
                                                                            class="btn btn-warning btn-sm" title="Edit">
                                                                            <i class="lni lni-pencil"></i>
                                                                        </a>

                                                                        <!-- Delete -->
                                                                        <a href="/product/delete/<%= product._id %>"
                                                                            class="btn btn-danger btn-sm"
                                                                            onclick="return confirm('Delete this product?')"
                                                                            title="Delete">
                                                                            <i class="lni lni-trash-can"></i>
                                                                        </a>

                                                                    </div>

                                                                </td>

                                                            </tr>

                                                            <% }) %>

                                                                <% if(products.length===0){ %>

                                                                    <tr>
                                                                        <td colspan="6" class="text-center text-muted">
                                                                            No Products Found
                                                                        </td>
                                                                    </tr>

                                                                    <% } %>

                                                    </tbody>

                                                </table>

                                            </div>

                                        </div>

                                    </div>
                                </section>

            </main>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

            <script>
                document.addEventListener("DOMContentLoaded", () => {

                    const alerts = document.querySelectorAll(".alert");

                    alerts.forEach(alert => {
                        setTimeout(() => {
                            const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                            bsAlert.close();
                        }, 3000);
                    });

                });
            </script>

    </body>

    </html>