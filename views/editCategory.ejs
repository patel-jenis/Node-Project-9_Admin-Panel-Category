<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Category</title>

    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.lineicons.com/4.0/lineicons.css">
    <link rel="stylesheet" href="/assets/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="/assets/css/fullcalendar.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
</head>

<body>

    <%- include('partials/aside') %>

        <main class="main-wrapper">

            <!-- Header -->
            <header class="header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-lg-5 col-md-5 col-6">
                            <div class="header-left d-flex align-items-center">
                                <div class="menu-toggle-btn mr-15">
                                    <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                        <i class="lni lni-chevron-left me-2"></i> Menu
                                    </button>
                                </div>

                                <div class="header-search d-none d-md-flex">
                                    <form action="#">
                                        <input type="text" placeholder="Search..." />
                                        <button>
                                            <i class="lni lni-search-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-7 col-md-7 col-6">
                            <div class="header-right d-flex justify-content-end align-items-center">

                                <div class="dropdown">

                                    <a href="#" class="text-decoration-none text-dark" id="profileDropdown"
                                        role="button" data-bs-toggle="dropdown">

                                        <div class="profile-box">
                                            <div class="profile-info">
                                                <div class="info d-flex align-items-center">

                                                    <div class="image me-2">
                                                        <img src="<%= user.image ? '/' + user.image : '/assets/images/profile/profile-image.png' %>"
                                                            alt="profile">
                                                    </div>

                                                    <div class="d-none d-sm-block">
                                                        <h6 class="fw-600 mb-0 text-capitalize">
                                                            <%= user.name %>
                                                        </h6>
                                                        <small class="text-muted">
                                                            <%= user.email %>
                                                        </small>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>

                                    </a>

                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-2">
                                        <li>
                                            <a class="dropdown-item py-2 rounded-3" href="/dashboard/profile">
                                                <i class="lni lni-user me-2"></i>
                                                My Profile
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item py-2 rounded-3" href="/auth/change-password">
                                                <i class="lni lni-lock-alt me-2"></i>
                                                Change Password
                                            </a>
                                        </li>

                                        <li>
                                            <hr class="dropdown-divider">
                                        </li>

                                        <li>
                                            <a class="dropdown-item logout-item" href="/auth/logout">
                                                <i class="lni lni-exit"></i>
                                                <span>Logout</span>
                                            </a>
                                        </li>
                                    </ul>

                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Edit Category Section -->
            <section class="section mt-5">
                <div class="container-fluid">

                    <div class="row">
                        <div class="col-12">

                            <div class="card-style">

                                <div class="title mb-4">
                                    <h4>Edit Category</h4>
                                    <p class="text-sm text-medium">
                                        Update the category name and save your changes.
                                    </p>
                                </div>

                                <% if (errorMsg) { %>
                                    <div class="alert alert-danger">
                                        <%= errorMsg %>
                                    </div>
                                    <% } %>

                                        <form action="/category/updateCategory" method="POST">

                                            <input type="hidden" name="id" value="<%= category._id %>">

                                            <div class="row">

                                                <div class="col-md-12">
                                                    <div class="input-style-1">
                                                        <label>Category Name</label>

                                                        <input type="text" name="categoryName"
                                                            value="<%= category.categoryName %>"
                                                            placeholder="Enter category name" required>
                                                    </div>
                                                </div>

                                                <div class="col-md-12">
                                                    <div class="d-flex gap-3">

                                                        <button type="submit" class="main-btn primary-btn btn-hover">
                                                            <i class="lni lni-save me-2"></i>
                                                            Update Category
                                                        </button>

                                                        <a href="/category/view-Category"
                                                            class="main-btn light-btn btn-hover">
                                                            Cancel
                                                        </a>

                                                    </div>
                                                </div>

                                            </div>

                                        </form>

                            </div>

                        </div>
                    </div>

                </div>
            </section>

        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>