<%- include('partials/authHeader') %>

    <body>

        <main class="min-vh-100 d-flex align-items-center justify-content-center bg-light">

            <div class="container">
                <div class="row justify-content-center">

                    <div class="col-lg-11 col-xl-10">

                        <div class="card shadow-lg border-0 overflow-hidden">

                            <div class="row g-0">

                                <!-- Left Side -->
                                <div
                                    class="col-md-6 bg-primary-100 d-flex align-items-center justify-content-center p-5">

                                    <div class="text-center">

                                        <h1 class="text-primary mb-3">
                                            Change Password
                                        </h1>

                                        <p class="text-medium mb-4">
                                            Update your password to keep your account secure.
                                        </p>

                                        <img src="../assets/images/auth/signin-image.svg" alt="change-password-image"
                                            class="img-fluid w-75">

                                    </div>

                                </div>

                                <!-- Right Side -->
                                <div class="col-md-6 d-flex align-items-center">

                                    <div class="w-100 p-sm-5 p-4">

                                        <h3 class="mb-3">
                                            Change Password
                                        </h3>

                                        <p class="text-muted mb-4">
                                            Enter your current password and choose a new one.
                                        </p>

                                        <% if(errorMsg) { %>
                                            <div class="alert alert-danger py-2 px-3 mb-3">
                                                <%= errorMsg %>
                                            </div>
                                            <% } %>

                                                <form id="form" action="/auth/changed-password" method="POST">

                                                    <div class="mb-3">
                                                        <label class="form-label">Current Password</label>

                                                        <div class="position-relative">
                                                            <input type="password" id="currentPassword"
                                                                name="currentPassword" class="form-control pe-5"
                                                                placeholder="Enter current password" required>

                                                            <i class="lni lni-eye position-absolute top-50 end-0 translate-middle-y me-3 password-toggle"
                                                                style="cursor: pointer;"></i>
                                                        </div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label">New Password</label>

                                                        <div class="position-relative">
                                                            <input type="password" id="password" name="newPassword"
                                                                class="form-control pe-5"
                                                                placeholder="Enter new password" required>

                                                            <i class="lni lni-eye position-absolute top-50 end-0 translate-middle-y me-3 password-toggle"
                                                                style="cursor: pointer;"></i>
                                                        </div>

                                                        <div id="passwordError" class="text-danger small mt-1"></div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label">Confirm New Password</label>

                                                        <div class="position-relative">
                                                            <input type="password" id="confirmPassword"
                                                                name="confirmPassword" class="form-control pe-5"
                                                                placeholder="Confirm new password" required>

                                                            <i class="lni lni-eye position-absolute top-50 end-0 translate-middle-y me-3 password-toggle"
                                                                style="cursor: pointer;"></i>
                                                        </div>
                                                    </div>

                                                    <div id="blockMessage" class="text-danger small mb-2"></div>

                                                    <button type="submit" id="changePasswordBtn"
                                                        class="btn btn-primary w-100 mt-3 py-2">
                                                        Change Password
                                                    </button>

                                                    <div class="text-center mt-3">
                                                        <a href="/dashboard/profile"
                                                            class="text-decoration-none fw-semibold">
                                                            Back to Profile
                                                        </a>
                                                    </div>

                                                </form>

                                    </div>

                                </div>
                                <!-- End Right Side -->

                            </div>

                        </div>

                    </div>

                </div>
            </div>

        </main>

        <div id="remainingTimeData" data-time="<%= remainingTime || 0 %>"></div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        <script>
            const form = document.getElementById("form");
            const passwordInput = document.getElementById("password");
            const passwordError = document.getElementById("passwordError");

            const strongPassword =
                /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&]).{8,}$/;

            function validatePassword() {
                if (passwordInput.value === "") {
                    passwordInput.classList.remove("is-invalid");
                    passwordError.textContent = "";
                    return;
                }

                if (!strongPassword.test(passwordInput.value)) {
                    passwordInput.classList.add("is-invalid");
                    passwordError.textContent =
                        "Password must contain at least 8 characters, one uppercase letter, one lowercase letter, one number, and one special character.";
                } else {
                    passwordInput.classList.remove("is-invalid");
                    passwordError.textContent = "";
                }
            }

            passwordInput.addEventListener("input", validatePassword);

            form.addEventListener("submit", function (e) {
                validatePassword();

                if (!strongPassword.test(passwordInput.value)) {
                    e.preventDefault();
                }
            });


            const passwordToggles = document.querySelectorAll(".password-toggle");

            passwordToggles.forEach((icon) => {
                icon.addEventListener("click", () => {
                    const input = icon.previousElementSibling;

                    input.type =
                        input.type === "password" ? "text" : "password";
                });
            });


            const changePasswordBtn = document.getElementById("changePasswordBtn");
            const blockMessage = document.getElementById("blockMessage");

            let timeLeft = Number(
                document.getElementById("remainingTimeData").dataset.time
            );

            if (timeLeft > 0) {
                changePasswordBtn.disabled = true;

                function updateTimer() {
                    const minutes = Math.floor(timeLeft / 60);
                    const seconds = timeLeft % 60;

                    blockMessage.textContent =
                        `Too many failed attempts. Try again in ${minutes}m ${seconds
                            .toString()
                            .padStart(2, "0")}s`;

                    if (timeLeft <= 0) {
                        clearInterval(timer);
                        changePasswordBtn.disabled = false;
                        blockMessage.textContent = "";
                        return;
                    }

                    timeLeft--;
                }

                updateTimer();
                const timer = setInterval(updateTimer, 1000);
            }
        </script>

    </body>

    </html>